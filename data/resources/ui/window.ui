<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <menu id="primary_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">_Preferences</attribute>
        <attribute name="action">app.preferences</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Keyboard Shortcuts</attribute>
        <attribute name="action">win.show-help-overlay</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_About Based</attribute>
        <attribute name="action">app.about</attribute>
      </item>
    </section>
  </menu>
  <template class="BasedApplicationWindow" parent="AdwApplicationWindow">
    <property name="default-width">800</property>
    <property name="default-height">600</property>
    <property name="content">
      <object class="AdwFlap" id="based_container">
        <property name="reveal-flap"
                  bind-source="flap_toggle"
                  bind-property="active" />
        <child type="flap">
          <object class="GtkBox" id="based_flap">
            <property name="orientation">vertical</property>
            <property name="halign">center</property>
            <property name="hexpand">false</property>
            <style>
              <class name="based-flap" />
            </style>
            <child>
              <object class="AdwHeaderBar" id="flap_headerbar">
                <property name="show-end-title-buttons">false</property>
                <child>
                  <object class="GtkButton" id="based_add_connection">
                    <property name="icon-name">list-add-symbolic</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="connection_list">
                <property name="orientation">vertical</property>
                <property name="hexpand">true</property>
                <property name="halign">start</property>
              </object>
            </child>
          </object>
        </child>
        <child type="content">
          <object class="GtkBox" id="based_content">
            <property name="orientation">vertical</property>
            <property name="hexpand">true</property>
            <child>
              <object class="AdwHeaderBar" id="content_headerbar">
                <child type="start">
                  <object class="GtkToggleButton" id="flap_toggle">
                    <property name="icon-name">sidebar-show-symbolic</property>
                    <property name="active">true</property>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkMenuButton" id="appmenu_button">
                    <property name="icon-name">open-menu-symbolic</property>
                    <property name="menu-model">primary_menu</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="content_container">
                <property name="orientation">vertical</property>
                <property name="hexpand">true</property>
                <property name="vexpand">true</property>
                <child>
                  <object class="GtkScrolledWindow" id="scripts_container">
                    <property name="hexpand">true</property>
                    <property name="vexpand">false</property>
                    <property name="height-request">120</property>
                    <child>
                      <object class="GtkTextView" id="scripts_input">
                        <property name="monospace">true</property>
                        <property name="vexpand">true</property>
                        <style>
                          <class name="scripts-input" />
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="data_view">
                    <property name="orientation">vertical</property>
                    <property name="hexpand">true</property>
                    <property name="vexpand">true</property>
                    <property name="halign">start</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child type="separator">
          <object class="GtkSeparator" />
        </child>
      </object>
    </property>
  </template>
</interface>
